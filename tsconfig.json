{
  "compilerOptions": {
    "target": "es2023",
    "module": "nodenext",
    "lib": [
      "es2023"
    ],
    "types": [
      "node"
    ],
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "erasableSyntaxOnly": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true
  },
  "include": [
    "collector",
    "shared"
  ]
}
