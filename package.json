{
  "name": "claude-monitor",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "node --test",
    "typecheck": "tsc --noEmit",
    "dev": "next dev web",
    "build": "next build web",
    "start": "next start web",
    "deploy": "npm run build && mkdir -p web/out/.vercel && cp web/.vercel/project.json web/out/.vercel/project.json && cd web/out && vercel deploy --prod --yes",
    "canary": "node scripts/canary.mjs web/out",
    "verify": "npm test && npm run typecheck && npm run build && npm run canary"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.8.0"
  },
  "dependencies": {
    "@visx/group": "^4.0.0",
    "@visx/scale": "^4.0.0",
    "@visx/shape": "^4.0.0",
    "next": "^16.2.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
